# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it is in .gitignore
#   4. This file (.env.example) IS committed — it shows teammates
#      which keys are needed, without revealing the actual values.
#
# VARIABLE RULES:
#   - EXPO_PUBLIC_ prefix  →  available inside your app code
#   - No prefix            →  only available in app.config.js (stays server-side)
# =============================================================================

# ── Environment profile ───────────────────────────────────────────────────────
# Controls which bundle ID, app name, and icon the build uses.
# Set to "development" on your machine, "production" for App Store builds.
APP_ENV=development

# ── RevenueCat (Subscriptions) ────────────────────────────────────────────────
# Get this from: https://app.revenuecat.com → Project Settings → API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AppLovin MAX (Ads) ────────────────────────────────────────────────────────
# Get these from: https://dash.applovin.com → Account → Keys
EXPO_PUBLIC_APPLOVIN_SDK_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_APPLOVIN_INTERSTITIAL_AD_UNIT_ID=xxxxxxxxxxxxxxxx

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" or "false" (always strings in .env files)
EXPO_PUBLIC_ADS_ENABLED=false
EXPO_PUBLIC_SUBSCRIPTIONS_ENABLED=false
